# Public HTTPS URL for this app, for example the URL printed by cloudflared.
PUBLIC_BASE_URL=https://YOUR_TUNNEL_URL

# Twilio phone-number configuration.
# TWILIO_PHONE_NUMBER is enough for configure_twilio_number.py if it is unique on the account.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+15551234567
TWILIO_PHONE_NUMBER_SID=
# Set to 0 if you only want the runner to print the Twilio webhook URL.
CONFIGURE_TWILIO_WEBHOOK=1

# Valsea speech-to-text settings.
# Put your real key in .env only. Do not commit secrets.
VALSEA_API_KEY=
VALSEA_TRANSCRIPTION_URL=https://api.valsea.ai/v1/audio/transcriptions
VALSEA_TRANSCRIPTION_MODEL=valsea-transcribe
# Valsea requires a language value. Use english, vietnamese, singlish, etc.
VALSEA_TRANSCRIPTION_LANGUAGE=english

# Optional OpenAI-compatible LLM reply generation.
# If unset, the app uses the local rule-based nail salon reply flow.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=

# Optional dashboard webhook for live transcript lines.
# The bridge can post to the local dashboard; the dashboard does not need its own tunnel.
TRANSCRIPT_WEBHOOK_URL=http://localhost:3000/message-webhook

# Bilingual Vietnamese nail salon prompt.
# Leave blank to use the default prompt embedded in valsea_adapter.py, or set your own override.
VALSEA_AGENT_ID=
VALSEA_AGENT_PROMPT=

# ElevenLabs text-to-speech settings.
# Use output_format=ulaw_8000 so audio can be sent directly back to Twilio Media Streams.
ELEVENLABS_API_KEY=
# Optional. Rachel is a clearer default receptionist voice when the account has quota.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=ulaw_8000
# Uses local espeak-ng fallback speech if ElevenLabs is out of quota or unavailable.
LOCAL_TTS_FALLBACK=1

# Buffer this many seconds of Twilio audio before one STT/TTS turn.
TURN_AUDIO_SECONDS=3.0
HTTP_TIMEOUT_SECONDS=30.0

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
