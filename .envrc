# Keep `cd cursorhackathon` fast and quiet. We avoid `use flake` here because
# nix-direnv exports the full mkShell build environment, which creates a huge
# `direnv: export +AR +CC ...` line on every prompt.
export DIRENV_LOG_FORMAT=-

watch_file flake.nix flake.lock package-lock.json

naiflow_dev_env="$(nix --no-warn-dirty build --no-link --print-out-paths .#dev-env)"
PATH_add "$naiflow_dev_env/bin"

export DATABASE_URL="${DATABASE_URL:-file:./dev.db}"
export npm_config_build_from_source="${npm_config_build_from_source:-true}"
export PRISMA_BINARY_TARGET="$(cat "$naiflow_dev_env/nix-support/prisma-target")"
export PRISMA_SCHEMA_ENGINE_BINARY="$PWD/node_modules/@prisma/engines/$(cat "$naiflow_dev_env/nix-support/prisma-schema-engine")"
export LD_LIBRARY_PATH="$(cat "$naiflow_dev_env/nix-support/runtime-libs")${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export PROMPT_COMMAND_RIGHT=
trap 'unset LD_LIBRARY_PATH' EXIT
